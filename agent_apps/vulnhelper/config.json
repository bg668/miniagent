{
  "subagents_dir": "subagents",
  "llm_profiles": {
    "dashscope_glm": {
      "provider": "openai",
      "api": "chat.completions",
      "base_url": "https://coding.dashscope.aliyuncs.com/v1",
      "api_key": "${OPENAI_API_KEY}",
      "default_model": "glm-5"
    }
  },
  "workflow_routes": {
    "new_query": ["planner"],
    "confirm": ["executor", "analyst"],
    "drilldown": ["executor"]
  },
  "max_table_rows": 50
}
